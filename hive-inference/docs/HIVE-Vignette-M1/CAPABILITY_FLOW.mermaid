---
title: HIVE Capability Flow & Tasking Architecture
---

%% This diagram shows bidirectional flow:
%% - Capabilities flow UPWARD (informing C2)
%% - Tasking flows DOWNWARD (based on known capabilities)
%% Render at: https://mermaid.live

flowchart TB
    subgraph C2["🏢 C2 Element - WebTAK"]
        direction TB
        CAP_VIEW["📊 Capability Dashboard<br/>━━━━━━━━━━━━━━━━━━━━<br/>✅ OBJECT_TRACKING: Ready<br/>&nbsp;&nbsp;&nbsp;&nbsp;• 2 platforms (Alpha-3, Bravo-3)<br/>&nbsp;&nbsp;&nbsp;&nbsp;• Model v1.2.0, Precision 0.91<br/>✅ SENSOR_COVERAGE: Ready<br/>&nbsp;&nbsp;&nbsp;&nbsp;• 2 cameras (UGV + UAV)<br/>✅ HUMAN_OVERSIGHT: Ready<br/>&nbsp;&nbsp;&nbsp;&nbsp;• 2 operators online"]
        
        TASK_DECISION{{"Commander Decision:<br/>'I have tracking capability<br/>across both sectors.<br/>I can task this mission.'"}}
        
        TASK_CMD["📋 TRACK_TARGET Command<br/>Target: Blue jacket, backpack<br/>Boundary: Sectors A+B"]
        
        CAP_VIEW --> TASK_DECISION
        TASK_DECISION --> TASK_CMD
    end

    subgraph Coord["🔗 Coordinator (Bridge)"]
        direction TB
        AGG["🔄 Capability Aggregator<br/>━━━━━━━━━━━━━━━━━━━━<br/>Alpha: Tracker v1.2.0 ✓<br/>Bravo: Tracker v1.2.0 ✓<br/>Combined: 2 teams READY"]
        
        ROUTER["📡 Command Router<br/>Distributes to capable teams"]
        
        AGG --> ROUTER
    end

    subgraph NetA["👥 Team Alpha (Network A)"]
        direction TB
        
        A_AGG["📦 Team Capability<br/>━━━━━━━━━━━━━━━━━<br/>Leader: Alpha-1<br/>Tracking: ✓<br/>Camera: ✓<br/>Human: ✓"]
        
        subgraph A_Platforms["Platform Capabilities"]
            A1["👤 Alpha-1<br/>OPERATOR<br/>Authority: SUPERVISOR<br/>Status: ONLINE"]
            A2["🤖 Alpha-2<br/>UGV + CAMERA<br/>Resolution: 1080p<br/>Status: READY"]
            A3["🧠 Alpha-3<br/>AI MODEL<br/>YOLOv8 v1.2.0<br/>Precision: 0.91<br/>FPS: 15<br/>Status: READY"]
        end
        
        A1 -->|"advertise"| A_AGG
        A2 -->|"advertise"| A_AGG
        A3 -->|"advertise"| A_AGG
    end

    subgraph NetB["👥 Team Bravo (Network B)"]
        direction TB
        
        B_AGG["📦 Team Capability<br/>━━━━━━━━━━━━━━━━━<br/>Leader: Bravo-1<br/>Tracking: ✓<br/>Camera: ✓<br/>Human: ✓"]
        
        subgraph B_Platforms["Platform Capabilities"]
            B1["👤 Bravo-1<br/>OPERATOR<br/>Authority: SUPERVISOR<br/>Status: ONLINE"]
            B2["🚁 Bravo-2<br/>UAV + CAMERA<br/>Resolution: 1080p<br/>Status: READY"]
            B3["🧠 Bravo-3<br/>AI MODEL<br/>YOLOv8 v1.2.0<br/>Precision: 0.91<br/>FPS: 15<br/>Status: READY"]
        end
        
        B1 -->|"advertise"| B_AGG
        B2 -->|"advertise"| B_AGG
        B3 -->|"advertise"| B_AGG
    end

    %% Upward capability flow (green arrows)
    A_AGG ==>|"⬆️ Capabilities"| AGG
    B_AGG ==>|"⬆️ Capabilities"| AGG
    AGG ==>|"⬆️ Aggregated<br/>Capabilities"| CAP_VIEW

    %% Downward tasking flow (blue arrows)
    TASK_CMD -.->|"⬇️ Task"| ROUTER
    ROUTER -.->|"⬇️ TRACK_TARGET"| A_AGG
    ROUTER -.->|"⬇️ TRACK_TARGET"| B_AGG

    %% Styling
    classDef c2Style fill:#1a237e,stroke:#fff,color:#fff
    classDef coordStyle fill:#00695c,stroke:#fff,color:#fff
    classDef teamStyle fill:#e65100,stroke:#fff,color:#fff
    classDef platformStyle fill:#37474f,stroke:#fff,color:#fff
    classDef capStyle fill:#1b5e20,stroke:#fff,color:#fff
    classDef taskStyle fill:#0d47a1,stroke:#fff,color:#fff
    classDef decisionStyle fill:#4a148c,stroke:#fff,color:#fff

    class C2 c2Style
    class Coord coordStyle
    class NetA,NetB teamStyle
    class A1,A2,A3,B1,B2,B3 platformStyle
    class CAP_VIEW,A_AGG,B_AGG,AGG capStyle
    class TASK_CMD,ROUTER taskStyle
    class TASK_DECISION decisionStyle
