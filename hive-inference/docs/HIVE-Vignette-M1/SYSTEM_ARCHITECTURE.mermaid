---
title: HIVE PoC - Object Tracking System Architecture
---

%% HIVE Object Tracking PoC - System Architecture Diagram
%% Render at: https://mermaid.live or in any Mermaid-compatible viewer

flowchart TB
    subgraph C2["🏢 C2 Element"]
        TAK_Server["TAK Server\n(CoT Hub)"]
        WebTAK["WebTAK\n(Commander UI)\n🌐 Browser"]
        MLOps["MLOps Server\n🧠 Model Training\n📦 Version Mgmt"]
        
        TAK_Server <-->|"HTTP/WS"| WebTAK
        MLOps -->|"Model Package"| TAK_Server
    end

    subgraph Coordinator["🔗 Coordinator Node (Network Bridge)"]
        direction TB
        Bridge["HIVE-TAK Bridge\n• CoT ↔ HIVE Translation\n• Track Aggregation\n• Handoff Orchestration\n• Model Distribution"]
        ATAK_Coord["ATAK\n(Coordinator UI)"]
        
        subgraph NetInterfaces["Network Interfaces"]
            NIC_A["Network A\nInterface"]
            NIC_B["Network B\nInterface"]
        end
        
        Bridge --> ATAK_Coord
        Bridge --> NIC_A
        Bridge --> NIC_B
    end

    subgraph TeamAlpha["👥 Team Alpha (Network A)"]
        direction TB
        
        subgraph Alpha_Human["Human Element"]
            Alpha1["Alpha-1: Operator\n📱 ATAK on Android\n🎖️ Authority: SUPERVISOR"]
        end
        
        subgraph Alpha_Machine["Machine Element"]
            Alpha2["Alpha-2: UGV\n🤖 Ground Robot\n📷 Camera Sensor\n📡 WiFi Mesh"]
        end
        
        subgraph Alpha_AI["AI Element"]
            Alpha3["Alpha-3: AI Model\n🧠 Jetson Edge GPU\n🔍 YOLOv8 Detector\n📊 DeepSORT Tracker\n📦 Hot-swappable"]
        end
        
        Alpha1 <-->|"HIVE Sync"| Alpha2
        Alpha2 -->|"Video Frames"| Alpha3
        Alpha3 -->|"Track Updates"| Alpha1
        Alpha3 -->|"Track Updates"| Alpha2
    end

    subgraph TeamBravo["👥 Team Bravo (Network B)"]
        direction TB
        
        subgraph Bravo_Human["Human Element"]
            Bravo1["Bravo-1: Operator\n📱 ATAK on Android\n🎖️ Authority: SUPERVISOR"]
        end
        
        subgraph Bravo_Machine["Machine Element"]
            Bravo2["Bravo-2: UAV\n🚁 Quadcopter\n📷 Camera Sensor\n📡 WiFi Mesh"]
        end
        
        subgraph Bravo_AI["AI Element"]
            Bravo3["Bravo-3: AI Model\n🧠 Jetson Edge GPU\n🔍 YOLOv8 Detector\n📊 DeepSORT Tracker\n📦 Hot-swappable"]
        end
        
        Bravo1 <-->|"HIVE Sync"| Bravo2
        Bravo2 -->|"Video Frames"| Bravo3
        Bravo3 -->|"Track Updates"| Bravo1
        Bravo3 -->|"Track Updates"| Bravo2
    end

    %% Cross-layer connections
    TAK_Server <-->|"CoT/TCP\n(Tracks ↑ Commands ↓)"| Bridge
    NIC_A <-->|"HIVE Protocol\n(Tracks ↑ Models ↓)"| Alpha1
    NIC_A <-->|"HIVE Protocol"| Alpha2
    NIC_A <-->|"HIVE Protocol"| Alpha3
    NIC_B <-->|"HIVE Protocol\n(Tracks ↑ Models ↓)"| Bravo1
    NIC_B <-->|"HIVE Protocol"| Bravo2
    NIC_B <-->|"HIVE Protocol"| Bravo3

    %% Styling
    classDef c2Style fill:#1a237e,stroke:#fff,color:#fff
    classDef coordStyle fill:#00695c,stroke:#fff,color:#fff
    classDef teamStyle fill:#bf360c,stroke:#fff,color:#fff
    classDef humanStyle fill:#1565c0,stroke:#fff,color:#fff
    classDef machineStyle fill:#558b2f,stroke:#fff,color:#fff
    classDef aiStyle fill:#6a1b9a,stroke:#fff,color:#fff

    class C2 c2Style
    class Coordinator coordStyle
    class TeamAlpha,TeamBravo teamStyle
    class Alpha_Human,Bravo_Human humanStyle
    class Alpha_Machine,Bravo_Machine machineStyle
    class Alpha_AI,Bravo_AI aiStyle
