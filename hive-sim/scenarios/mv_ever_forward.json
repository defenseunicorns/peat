      "events_file": "events/ship_arrival.json"
    },
    {
      "phase_id": "hazmat-gap-resolution",
      "trigger_cycle": 60,
      "name": "Gap Resolution (Hazmat Recertification)",
      "description": "3 workers with expired hazmat certs identified and targeted for recertification.",
      "events_file": "events/hazmat_gap_resolution.json"
    },
    {
      "phase_id": "equipment-degradation",
      "trigger_cycle": 360,
      "name": "Equipment Degradation",
      "description": "Crane-2 hydraulic issue. Reduced capacity triggers container redistribution.",
      "events_file": "events/equipment_degradation.json"
    },
    {
      "phase_id": "shift-change",
      "trigger_cycle": 720,
      "name": "Shift Change",
      "description": "Half workforce transitions OFFLINE. Arriving workers register. Teams dynamically reform.",
      "events_file": "events/shift_change.json"
    }
  ],
