{
  "scenario_id": "mv-ever-forward",
  "name": "MV Ever Forward - Multi-Hold Container Operations",
  "description": "ADR-051 Phase 2 scenario: container vessel unloading with dynamic disruptions. Tests hierarchical coordination across 3 holds with equipment degradation, workforce changes, and capability gaps.",
  "vessel": {
    "name": "MV Ever Forward",
    "imo": "9811000",
    "containers_total": 1200,
    "holds": ["hold-1", "hold-2", "hold-3"],
    "berth": "berth-7"
  },
  "cycle_duration_ms": 5000,
  "phases": [
    {
      "phase_id": "ship-arrival",
      "trigger_cycle": 0,
