# Ditto Configuration for CAP Simulation
# Copy this to .env and fill in your credentials from Ditto portal
#
# Get credentials from: https://portal.ditto.live/

# Application ID (UUID format)
DITTO_APP_ID=***REMOVED***

# Offline license token (long base64 string)
DITTO_OFFLINE_TOKEN=***REMOVED***

# Shared encryption key (base64 string)
DITTO_SHARED_KEY=***REMOVED***
