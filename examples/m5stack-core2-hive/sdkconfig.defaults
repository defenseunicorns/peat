# HIVE M5Stack Core2 ESP-IDF Configuration

# Rust runtime
CONFIG_ESP_MAIN_TASK_STACK_SIZE=32768

# Bluetooth
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=4
CONFIG_BT_NIMBLE_MAX_BONDS=3
CONFIG_BT_NIMBLE_MAX_CCCDS=8
CONFIG_BT_NIMBLE_SVC_GAP_DEVICE_NAME="HIVE-M5Core2"
CONFIG_BT_NIMBLE_GAP_DEVICE_NAME_MAX_LEN=32
CONFIG_BT_NIMBLE_ATT_PREFERRED_MTU=512
CONFIG_BT_NIMBLE_50_FEATURE_SUPPORT=n

# GATT
CONFIG_BT_NIMBLE_NVS_PERSIST=y
CONFIG_BT_NIMBLE_ROLE_CENTRAL=y
CONFIG_BT_NIMBLE_ROLE_PERIPHERAL=y
CONFIG_BT_NIMBLE_ROLE_BROADCASTER=y
CONFIG_BT_NIMBLE_ROLE_OBSERVER=y

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_VERBOSE=y

# Power management (for M5Stack Core2)
CONFIG_PM_ENABLE=y
CONFIG_PM_DFS_INIT_AUTO=y

# Flash size (M5Stack Core2 has 16MB)
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
# Use single factory partition (4MB max app size)
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y

# PSRAM (M5Stack Core2 has 8MB PSRAM)
CONFIG_ESP32_SPIRAM_SUPPORT=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=4096

# Watchdog
CONFIG_ESP_TASK_WDT_TIMEOUT_S=30

# Optimize for size
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
